{
  "name": "marketing-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "analyze": "ANALYZE=true next build --webpack",
    "start": "next start",
    "lint": "eslint --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test:run": "vitest run --passWithNoTests",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
