    "test:e2e": "playwright test",
    "test:storybook": "vitest run --project storybook --passWithNoTests"
  },
  "dependencies": {
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
